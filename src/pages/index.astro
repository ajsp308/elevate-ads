---
import '../styles/global.css';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="facebook-domain-verification" content="3zfdfn9ywow9mgvl0qzm51okraot2e" />
    <title>Elevate Ads — Paquetes de Marketing en Redes Sociales</title>
  </head>
  <body class="bg-zinc-900 min-h-screen">

    <!-- Header -->
    <header class="w-full py-6 flex justify-center items-center bg-black">
      <span class="text-2xl font-bold text-white tracking-widest">ELEVATE</span>
    </header>

    <!-- Hero Section -->
    <section id="hero" class="relative h-[300vh]">
      <div class="sticky top-0 h-screen w-full overflow-hidden">
        <canvas id="hero-canvas" class="w-full h-full" style="image-rendering: auto;"></canvas>
      </div>
    </section>

    <!-- Pricing Section -->
    <section class="py-20 px-4 bg-black">

      <!-- Header -->
      <div class="text-center mb-14">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight max-w-3xl mx-auto">
          Elige tu Paquete de Marketing en Redes Sociales
        </h1>
      </div>

      <!-- Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto items-start">

        <!-- BRONZE -->
        <div class="bg-white rounded-2xl p-8 flex flex-col gap-6 shadow-lg">
          <div>
            <h2 class="text-2xl font-extrabold text-blue-600 tracking-widest uppercase">Basic</h2>
            <p class="text-4xl font-bold text-zinc-900 mt-2">€349 <span class="text-lg font-medium text-zinc-500">/ mes</span></p>
            <p class="text-purple-600 font-semibold mt-1">Iniciante</p>
          </div>

          <ul class="flex flex-col gap-3 text-zinc-700 text-sm">
            {[
              "4 Publicaciones en Redes Sociales",
              "1 Reel Corto",
              "1 AI-powered META-ADS",
              "Gestión de Anuncios",
              "Reporte Mensual",
              "Planificación de Contenido",
            ].map((item) => (
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-blue-600 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>

          <button class="mt-auto w-full py-3 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-semibold transition-colors">
            Comenzar
          </button>
        </div>

        <!-- SILVER (Most Popular) -->
        <div class="relative bg-white rounded-2xl p-8 flex flex-col gap-6 shadow-xl ring-2 ring-gray-400">
          <!-- Badge -->
          <span class="absolute -top-4 left-1/2 -translate-x-1/2 bg-gray-500 text-white text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-widest whitespace-nowrap">
            Más Popular
          </span>

          <div>
            <h2 class="text-2xl font-extrabold text-gray-400 tracking-widest uppercase">Standard</h2>
            <p class="text-4xl font-bold text-zinc-900 mt-2">€799 <span class="text-lg font-medium text-zinc-500">/ mes</span></p>
            <p class="text-purple-600 font-semibold mt-1">Plus</p>
          </div>

          <ul class="flex flex-col gap-3 text-zinc-700 text-sm">
            {[
              "8 Publicaciones en Redes Sociales",
              "2 Reels Profesionales",
              "AI-powered META-ADS",
              "Gestión de Anuncios",
              "Reporte Mensual",
              "Planificación de Contenido",
            ].map((item) => (
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-gray-400 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>

          <button class="mt-auto w-full py-3 rounded-xl bg-gray-400 hover:bg-gray-500 text-white font-semibold transition-colors">
            Comenzar
          </button>
        </div>

        <!-- GOLD -->
        <div class="bg-white rounded-2xl p-8 flex flex-col gap-6 shadow-lg">
          <div>
            <h2 class="text-2xl font-extrabold text-yellow-500 tracking-widest uppercase">Premium</h2>
            <p class="text-4xl font-bold text-zinc-900 mt-2">€1299 <span class="text-lg font-medium text-zinc-500">/ mes</span></p>
            <p class="text-purple-600 font-semibold mt-1">Pro</p>
          </div>

          <ul class="flex flex-col gap-3 text-zinc-700 text-sm">
            {[
              "12 Publicaciones en Redes Sociales",
              "2 Reels Pro + 1 Reel con IA",
              "AI-powered META-ADS",
              "Gestión de Anuncios",
              "Reporte y Planificación Mensual",
            ].map((item) => (
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-yellow-500 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>

          <button class="mt-auto w-full py-3 rounded-xl bg-yellow-500 hover:bg-yellow-600 text-white font-semibold transition-colors">
            Comenzar
          </button>
        </div>

      </div>
    </section>

    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
      const ctx = canvas.getContext('2d')!;

      const FRAME_START  = 31;
      const FRAME_END    = 105;
      const TOTAL_FRAMES = FRAME_END - FRAME_START + 1; // 75
      const CACHE_V      = '2';
      const PATTERN = (i: number) =>
        `/INICIO/INICIO_${String(i).padStart(5, '0')}.jpg?v=${CACHE_V}`;

      const images: HTMLImageElement[] = [];
      const frameObj = { frame: 0 };
      let imagesLoaded = 0;

      function setCanvasSize() {
        const dpr = window.devicePixelRatio || 1;
        canvas.width  = window.innerWidth  * dpr;
        canvas.height = window.innerHeight * dpr;
        canvas.style.width  = window.innerWidth  + 'px';
        canvas.style.height = window.innerHeight + 'px';
        ctx.scale(dpr, dpr);
        ctx.imageSmoothingEnabled = true;
        ctx.imageSmoothingQuality = 'high';
      }

      function drawFrame(index: number) {
        const img = images[index];
        if (!img || !img.complete) return;
        const dpr = window.devicePixelRatio || 1;
        const displayW = canvas.width  / dpr;
        const displayH = canvas.height / dpr;
        ctx.clearRect(0, 0, displayW, displayH);
        const scale = Math.max(displayW / img.naturalWidth, displayH / img.naturalHeight);
        const w = img.naturalWidth  * scale;
        const h = img.naturalHeight * scale;
        const x = (displayW - w) / 2;
        const y = (displayH - h) / 2;
        ctx.drawImage(img, x, y, w, h);
      }

      function initAnimation() {
        setCanvasSize();
        drawFrame(0);

        gsap.to(frameObj, {
          frame: TOTAL_FRAMES - 1,
          ease: 'none',
          scrollTrigger: {
            trigger: '#hero',
            start: 'top top',
            end: 'bottom bottom',
            scrub: 0.5,
            onUpdate: (self) => {
              const index = Math.round(self.progress * (TOTAL_FRAMES - 1));
              drawFrame(index);
            },
          },
        });
      }

      function preloadImages() {
        for (let i = FRAME_START; i <= FRAME_END; i++) {
          const img = new Image();
          img.src = PATTERN(i);
          img.onload = () => {
            imagesLoaded++;
            if (imagesLoaded === TOTAL_FRAMES) initAnimation();
          };
          images[i - FRAME_START] = img;
        }
      }

      setCanvasSize();
      preloadImages();

      window.addEventListener('resize', () => {
        setCanvasSize();
        drawFrame(Math.round(frameObj.frame));
      });
    </script>
  </body>
</html>
