---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="facebook-domain-verification" content="3zfdfn9ywow9mgvl0qzm51okraot2e" />
    <title>Elevate Ads — Paquetes de Marketing en Redes Sociales</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
    <style>
      html, body { font-family: 'Inter', sans-serif; margin: 0; padding: 0; }

      /* ── Móvil: anclaje superior absoluto ── */
      @media (max-width: 767px) {
        html, body {
          margin-top: 0 !important;
          padding-top: 0 !important;
          overflow-x: hidden;
        }
        #hero {
          margin-top: 0 !important;
          padding-top: 0 !important;
        }
        #hero-sticky {
          top: 0 !important;
          margin-top: 0 !important;
          padding-top: 0 !important;
        }
        #hero-canvas {
          display: block !important;
          top: 0 !important;
          left: 0 !important;
          margin: 0 !important;
          padding: 0 !important;
          /* object-fit/position no aplica a canvas: el posicionamiento
             real lo gestiona drawFrame() con cover + y=0 en JS */
        }
      }
    </style>
  </head>
  <body class="bg-zinc-900 min-h-screen m-0 p-0">

    <!-- Hero Section -->
    <section id="hero" class="relative h-[300dvh]" style="margin-top:0;padding-top:0;">
      <div id="hero-sticky" class="sticky top-0 w-full overflow-hidden" style="top:0;margin-top:0;padding-top:0;height:100dvh;">
        <canvas id="hero-canvas" style="display:block;width:100%;height:100%;image-rendering:auto;margin:0;padding:0;"></canvas>
        <!-- Gradientes de transición superior e inferior -->
        <div class="absolute inset-x-0 top-0 h-24 bg-gradient-to-b from-black to-transparent pointer-events-none"></div>
        <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-black to-transparent pointer-events-none"></div>
      </div>
    </section>

    <!-- Pricing Section -->
    <section class="py-20 px-4 bg-black">

      <!-- Header -->
      <div class="text-center mb-20">
        <h1 class="text-3xl md:text-6xl font-bold tracking-tight max-w-4xl mx-auto leading-tight text-slate-50">
          Aumenta tus Ventas <span class="text-[#10b981]">HOY</span>, Elije el Plan que Dominara tu mercado
        </h1>
      </div>

      <!-- Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto items-start">

        <!-- BASIC -->
        <div class="bg-[#0f1115]/80 backdrop-blur-2xl border border-blue-500/20 rounded-2xl p-8 flex flex-col gap-6">
          <!-- Icon -->
          <div class="w-12 h-12 rounded-full bg-blue-500/10 flex items-center justify-center">
            <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <div>
            <h2 class="font-orbitron text-sm font-black uppercase tracking-[0.2em] text-[#60a5fa]">Basic</h2>
            <p class="text-5xl font-bold text-white tracking-tighter mt-2">$699<span class="text-base font-normal text-slate-400 ml-1">/mes</span></p>
            <p class="text-[#60a5fa] font-semibold mt-1">Iniciante</p>
          </div>
          <ul class="flex flex-col gap-5">
            {[
              "4 Publicaciones en Redes Sociales",
              "1 Reel Corto",
              "1 AI-powered META-ADS",
              "Gestión de Anuncios",
              "Reporte Mensual",
              "Planificación de Contenido",
            ].map((item) => (
              <li class="flex items-center gap-3">
                <span class="w-[14px] h-[14px] rounded-full border border-[#60a5fa] flex items-center justify-center shrink-0">
                  <svg class="w-[8px] h-[8px] text-[#60a5fa]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                <span class="text-[14px] font-medium text-slate-300 leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
          <a href="/contacto?plan=basic" class="mt-auto w-full py-3 rounded-xl bg-gradient-to-r from-blue-700 to-blue-500 hover:brightness-110 text-base font-bold text-white tracking-wide transition-all flex items-center justify-center gap-2">
            Comenzar <span>→</span>
          </a>
        </div>

        <!-- STANDARD (Most Popular) -->
        <div class="relative bg-[#0f1115]/80 backdrop-blur-2xl border-2 border-[#10b981] rounded-2xl p-8 flex flex-col gap-6 shadow-[0_0_25px_rgba(16,185,129,0.4)]">
          <!-- Badge -->
          <span class="absolute -top-4 left-1/2 -translate-x-1/2 bg-[#10b981] text-black text-[10px] font-black px-4 py-1.5 rounded-full uppercase tracking-widest whitespace-nowrap">
            MÁS POPULAR
          </span>
          <!-- Icon -->
          <div class="w-12 h-12 rounded-full bg-[#10b981]/10 flex items-center justify-center">
            <svg class="w-6 h-6 text-[#10b981]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
            </svg>
          </div>
          <div>
            <h2 class="font-orbitron text-sm font-black uppercase tracking-[0.2em] text-[#10b981]">Standard</h2>
            <p class="text-5xl font-bold text-white tracking-tighter mt-2">$1,399<span class="text-base font-normal text-slate-400 ml-1">/mes</span></p>
            <p class="text-[#10b981] font-semibold mt-1">Plus</p>
          </div>
          <ul class="flex flex-col gap-5">
            {[
              "8 Publicaciones en Redes Sociales",
              "2 Reels Profesionales",
              "AI-powered META-ADS",
              "Gestión de Anuncios",
              "Reporte Mensual",
              "Planificación de Contenido",
            ].map((item) => (
              <li class="flex items-center gap-3">
                <span class="w-[14px] h-[14px] rounded-full border border-[#10b981] flex items-center justify-center shrink-0">
                  <svg class="w-[8px] h-[8px] text-[#10b981]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                <span class="text-[14px] font-medium text-slate-300 leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
          <a href="/contacto?plan=standard" class="mt-auto w-full py-3 rounded-xl bg-gradient-to-r from-[#10b981] to-[#34d399] hover:brightness-110 text-base font-bold text-white tracking-wide transition-all flex items-center justify-center gap-2">
            Comenzar <span>→</span>
          </a>
        </div>

        <!-- PREMIUM -->
        <div class="bg-[#0f1115]/80 backdrop-blur-2xl border border-amber-500/20 rounded-2xl p-8 flex flex-col gap-6">
          <!-- Icon -->
          <div class="w-12 h-12 rounded-full bg-amber-500/10 flex items-center justify-center">
            <svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 3l1.5 4.5L12 5l5.5 2.5L19 3l-1 6H6L5 3zM6 9h12v2a6 6 0 01-12 0V9zM9 21h6M12 19v2" />
            </svg>
          </div>
          <div>
            <h2 class="font-orbitron text-sm font-black uppercase tracking-[0.2em] text-[#fbbf24]">Premium</h2>
            <p class="text-5xl font-bold text-white tracking-tighter mt-2">$1,899<span class="text-base font-normal text-slate-400 ml-1">/mes</span></p>
            <p class="text-[#fbbf24] font-semibold mt-1">Pro</p>
          </div>
          <ul class="flex flex-col gap-5">
            {[
              "12 Publicaciones en Redes Sociales",
              "2 Reels Pro + 1 Reel con IA",
              "AI-powered META-ADS",
              "Gestión de Anuncios",
              "Reporte Mensual",
              "Planificación de Contenido",
            ].map((item) => (
              <li class="flex items-center gap-3">
                <span class="w-[14px] h-[14px] rounded-full border border-[#fbbf24] flex items-center justify-center shrink-0">
                  <svg class="w-[8px] h-[8px] text-[#fbbf24]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                <span class="text-[14px] font-medium text-slate-300 leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
          <a href="/contacto?plan=premium" class="mt-auto w-full py-3 rounded-xl bg-gradient-to-r from-[#d97706] to-[#fbbf24] hover:brightness-110 text-base font-bold text-white tracking-wide transition-all flex items-center justify-center gap-2">
            Comenzar <span>→</span>
          </a>
        </div>

      </div>

      <!-- Barra de Garantías -->
      <div class="max-w-6xl mx-auto mt-12 bg-white/5 border border-white/10 rounded-2xl px-8 py-5 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div class="flex flex-col items-center gap-2">
          <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-sm font-bold text-white">Sin permanencia</span>
          <span class="text-xs font-normal text-slate-400">Cancela cuando quieras</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
          </svg>
          <span class="text-sm font-bold text-white">Pago seguro</span>
          <span class="text-xs font-normal text-slate-400">100% cifrado</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
          </svg>
          <span class="text-sm font-bold text-white">Soporte</span>
          <span class="text-xs font-normal text-slate-400">Respuesta en 24h</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
          </svg>
          <span class="text-sm font-bold text-white">Resultados</span>
          <span class="text-xs font-normal text-slate-400">Métricas reales</span>
        </div>
      </div>

    </section>

    <Footer />

    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
      const ctx = canvas.getContext('2d')!;

      const isMobile = window.innerWidth < 768;

      const DESKTOP = { start: 31, end: 105, pattern: (i: number) => `/INICIO/INICIO_${String(i).padStart(5, '0')}.jpg?v=2` };
      const MOBILE  = { start: 0,  end: 90,  pattern: (i: number) => `/MOVIL/MOVIL_${String(i).padStart(5, '0')}.jpg?v=3` };
      const CONFIG  = isMobile ? MOBILE : DESKTOP;

      const TOTAL_FRAMES = CONFIG.end - CONFIG.start + 1;
      const QUICK_FRAMES = 15;
      const images: HTMLImageElement[] = new Array(TOTAL_FRAMES);
      const frameObj = { frame: 0 };
      let animationReady = false;

      function setCanvasSize() {
        const dpr = window.devicePixelRatio || 1;
        const W = window.innerWidth;
        // En móvil usamos visualViewport para respetar la barra del navegador
        const H = (isMobile && window.visualViewport)
          ? window.visualViewport.height
          : window.innerHeight;
        canvas.width  = W * dpr;
        canvas.height = H * dpr;
        canvas.style.width  = W + 'px';
        canvas.style.height = H + 'px';
        // Reescala el contexto 2D limpiamente en cada resize
        ctx.setTransform(1, 0, 0, 1, 0, 0);
        ctx.scale(dpr, dpr);
        ctx.imageSmoothingEnabled = true;
        ctx.imageSmoothingQuality = 'high';
      }

      function drawFrame(index: number) {
        const img = images[index];
        if (!img || !img.complete) return;
        const dpr = window.devicePixelRatio || 1;
        const displayW = canvas.width / dpr;
        const displayH = canvas.height / dpr;
        ctx.fillStyle = '#000000';
        ctx.fillRect(0, 0, displayW, displayH);

        let w: number, h: number, x: number, y: number;

        if (isMobile) {
          // Cover + anchor top: la imagen (1054×1492) cubre toda la pantalla sin negro arriba
          const scale = Math.max(displayW / img.naturalWidth, displayH / img.naturalHeight);
          w = img.naturalWidth  * scale;
          h = img.naturalHeight * scale;
          x = (displayW - w) / 2;
          y = 0;
        } else {
          // Desktop: ajuste al ancho con margen, centrado vertical
          const scale = (displayW / img.naturalWidth) * 0.95;
          w = img.naturalWidth  * scale;
          h = img.naturalHeight * scale;
          x = (displayW - w) / 2;
          y = (displayH - h) / 2;
        }

        ctx.filter = 'contrast(1.05) brightness(1.02)';
        ctx.drawImage(img, x, y, w, h);
        ctx.filter = 'none';
      }

      function initAnimation() {
        if (animationReady) return;
        animationReady = true;
        drawFrame(0);

        gsap.to(frameObj, {
          frame: TOTAL_FRAMES - 1,
          ease: 'none',
          scrollTrigger: {
            trigger: '#hero',
            start: 'top top',
            end: 'bottom bottom',
            scrub: 0.5,
            onUpdate: (self) => {
              const index = Math.round(self.progress * (TOTAL_FRAMES - 1));
              drawFrame(index);
            },
          },
        });
      }

      function preloadImages() {
        let quickLoaded = 0;

        // Primeros 15 frames con alta prioridad — arrancan la animación sin bloquear
        for (let i = CONFIG.start; i < CONFIG.start + QUICK_FRAMES; i++) {
          const img = new Image();
          (img as any).fetchpriority = 'high';
          img.src = CONFIG.pattern(i);
          img.onload = () => {
            quickLoaded++;
            if (quickLoaded === 1) drawFrame(0);
            if (quickLoaded === QUICK_FRAMES) initAnimation();
          };
          images[i - CONFIG.start] = img;
        }

        // Resto de frames en segundo plano sin bloquear
        for (let i = CONFIG.start + QUICK_FRAMES; i <= CONFIG.end; i++) {
          const img = new Image();
          img.src = CONFIG.pattern(i);
          images[i - CONFIG.start] = img;
        }
      }

      setCanvasSize();
      preloadImages();

      window.addEventListener('resize', () => {
        setCanvasSize();
        drawFrame(Math.round(frameObj.frame));
      });
    </script>
  </body>
</html>
