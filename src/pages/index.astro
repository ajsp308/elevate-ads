    <Footer />

    <script>
      // ── MÓVIL (<768px) ──────────────────────────────────────────────────────
      if (window.innerWidth < 768) {
        const { gsap } = await import('gsap');
        const { ScrollTrigger } = await import('gsap/ScrollTrigger');
        gsap.registerPlugin(ScrollTrigger);

        const canvas = document.getElementById('hero-canvas-mobile') as HTMLCanvasElement;
        const ctx = canvas.getContext('2d')!;

        const TOTAL = 50;
        const QUICK = 15;
        const url = (i: number) => `/MWEB/MWEB_${String(i).padStart(5, '0')}.jpg`;

        const imgs: HTMLImageElement[] = new Array(TOTAL);
        let target = 0, current = 0;
        let W = 0, H = 0;
        let rafPending = false;

        function resize() {
          const dpr = window.devicePixelRatio || 1;
          W = window.innerWidth;
          H = window.innerHeight;
          canvas.width  = W * dpr;
          canvas.height = H * dpr;
          canvas.style.width  = W + 'px';
          canvas.style.height = H + 'px';
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
          ctx.imageSmoothingEnabled = true;
          ctx.imageSmoothingQuality = 'high';
        }

        function draw(idx: number) {
          const i = Math.max(0, Math.min(TOTAL - 1, Math.round(idx)));
          const img = imgs[i];
          if (!img?.complete) return;
          ctx.fillStyle = '#000';
          ctx.fillRect(0, 0, W, H);
          const scale = Math.max(W / img.naturalWidth, H / img.naturalHeight);
          const dw = img.naturalWidth  * scale;
          const dh = img.naturalHeight * scale;
          ctx.drawImage(img, (W - dw) / 2, (H - dh) / 2, dw, dh);
        }

        // RAF bajo demanda: solo corre mientras hay diferencia, para cuando se detiene
        function tick() {
          rafPending = false;
          const diff = target - current;
          if (Math.abs(diff) > 0.05) {
            current += diff * 0.2;
            draw(current);
            scheduleRaf();
          } else if (current !== target) {
            current = target;
            draw(current);
          }
        }

        function scheduleRaf() {
          if (!rafPending) { rafPending = true; requestAnimationFrame(tick); }
        }

        function init() {
          draw(0);
          ScrollTrigger.create({
            trigger: '#hero-mobile',
            start: 'top top',
            end: 'bottom bottom',
            onUpdate: (self) => {
              target = self.progress * (TOTAL - 1);
              scheduleRaf();
            },
          });
        }

        let resizeTimer: ReturnType<typeof setTimeout>;
        function onResize() {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(() => { resize(); draw(current); }, 150);
        }

        function preload() {
          let loaded = 0;
          for (let i = 0; i < QUICK; i++) {
            const img = new Image();
            img.decoding = 'async';
            (img as any).fetchpriority = 'high';
            img.src = url(i);
            img.onload = () => { if (++loaded === 1) draw(0); if (loaded === QUICK) init(); };
            imgs[i] = img;
          }
          for (let i = QUICK; i < TOTAL; i++) {
            const img = new Image();
            img.decoding = 'async';
            img.src = url(i);
            imgs[i] = img;
          }
        }

        resize();
        preload();
        window.addEventListener('resize', onResize, { passive: true });
      }
    </script>

    <script>
      // ── DESKTOP (≥768px) ────────────────────────────────────────────────────
      if (window.innerWidth >= 768) {
        const { gsap } = await import('gsap');
        const { ScrollTrigger } = await import('gsap/ScrollTrigger');
        gsap.registerPlugin(ScrollTrigger);

        const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
        const ctx = canvas.getContext('2d')!;

        const START = 31, END = 105;
        const TOTAL_FRAMES = END - START + 1;
        const QUICK_FRAMES = 15;
        const pattern = (i: number) => `/INICIO/INICIO_${String(i).padStart(5, '0')}.jpg?v=2`;

        const images: HTMLImageElement[] = new Array(TOTAL_FRAMES);
        let currentIdx = 0;
        let animationReady = false;
        let W = 0, H = 0;

        function setCanvasSize() {
          const dpr = window.devicePixelRatio || 1;
          W = window.innerWidth;
          H = window.innerHeight;
          canvas.width  = W * dpr;
          canvas.height = H * dpr;
          canvas.style.width  = W + 'px';
          canvas.style.height = H + 'px';
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
          ctx.imageSmoothingEnabled = true;
          ctx.imageSmoothingQuality = 'high';
        }

        function drawFrame(index: number) {
          const img = images[index];
          if (!img?.complete) return;
          ctx.fillStyle = '#000';
          ctx.fillRect(0, 0, W, H);
          const scale = (W / img.naturalWidth) * 0.95;
          const w = img.naturalWidth  * scale;
          const h = img.naturalHeight * scale;
          ctx.filter = 'contrast(1.05) brightness(1.02)';
          ctx.drawImage(img, (W - w) / 2, (H - h) / 2, w, h);
          ctx.filter = 'none';
        }

        function initAnimation() {
          if (animationReady) return;
          animationReady = true;
          drawFrame(0);
          gsap.to({ f: 0 }, {
            f: TOTAL_FRAMES - 1,
            ease: 'none',
            scrollTrigger: {
              trigger: '#hero',
              start: 'top top',
              end: 'bottom bottom',
              scrub: 0.5,
              onUpdate: (self) => {
                currentIdx = Math.round(self.progress * (TOTAL_FRAMES - 1));
                drawFrame(currentIdx);
              },
            },
          });
        }

        function preloadImages() {
          let quickLoaded = 0;
          for (let i = START; i < START + QUICK_FRAMES; i++) {
            const img = new Image();
            img.decoding = 'async';
            (img as any).fetchpriority = 'high';
            img.src = pattern(i);
            img.onload = () => {
              quickLoaded++;
              if (quickLoaded === 1) drawFrame(0);
              if (quickLoaded === QUICK_FRAMES) initAnimation();
            };
            images[i - START] = img;
          }
          for (let i = START + QUICK_FRAMES; i <= END; i++) {
            const img = new Image();
            img.decoding = 'async';
            img.src = pattern(i);
            images[i - START] = img;
          }
        }

        let resizeTimer: ReturnType<typeof setTimeout>;
        setCanvasSize();
        preloadImages();
        window.addEventListener('resize', () => {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(() => { setCanvasSize(); drawFrame(currentIdx); }, 150);
        }, { passive: true });
      }
    </script>

  </body>
</html>
