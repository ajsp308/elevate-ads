    <script>
      (function () {
        var currentMode = 'completo';

        function movePill(btn) {
          var toggle = document.getElementById('pricing-toggle');
          var pill = document.getElementById('toggle-pill');
          var tRect = toggle.getBoundingClientRect();
          var bRect = btn.getBoundingClientRect();
          pill.style.left = (bRect.left - tRect.left) + 'px';
          pill.style.width = bRect.width + 'px';
        }

        function setPricingMode(mode) {
          if (mode === currentMode) return;
          currentMode = mode;

          var gridCompleto = document.getElementById('grid-completo');
          var gridGestion = document.getElementById('grid-gestion');
          var btnCompleto = document.getElementById('btn-completo');
          var btnGestion = document.getElementById('btn-gestion');

          var activeGrid = mode === 'completo' ? gridCompleto : gridGestion;
          var inactiveGrid = mode === 'completo' ? gridGestion : gridCompleto;
          var activeBtn = mode === 'completo' ? btnCompleto : btnGestion;
          var inactiveBtn = mode === 'completo' ? btnGestion : btnCompleto;

          movePill(activeBtn);
          activeBtn.style.color = '#000';
          inactiveBtn.style.color = '#94a3b8';

          inactiveGrid.style.opacity = '0';
          setTimeout(function () {
            inactiveGrid.style.display = 'none';
            activeGrid.style.display = 'grid';
            requestAnimationFrame(function () {
              requestAnimationFrame(function () {
                activeGrid.style.opacity = '1';
              });
            });
          }, 250);
        }

        document.addEventListener('DOMContentLoaded', function () {
          var btnCompleto = document.getElementById('btn-completo');
          var btnGestion = document.getElementById('btn-gestion');

          btnCompleto.addEventListener('click', function () { setPricingMode('completo'); });
          btnGestion.addEventListener('click', function () { setPricingMode('gestion'); });

          movePill(btnCompleto);
        });
      })();
    </script>

